{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course",
    "description": "An individual course linked to an education entry"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "grade": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "education": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::education.education",
      "inversedBy": "courses"
    }
  }
}
