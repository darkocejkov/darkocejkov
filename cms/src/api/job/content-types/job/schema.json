{
  "kind": "collectionType",
  "collectionName": "jobs",
  "info": {
    "singularName": "job",
    "pluralName": "jobs",
    "displayName": "Job",
    "description": "Professional work experience entry"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "company": {
      "type": "string",
      "required": true
    },
    "location": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "startDate": {
      "type": "date",
      "required": true
    },
    "endDate": {
      "type": "date"
    },
    "current": {
      "type": "boolean",
      "default": false
    },
    "summary": {
      "type": "richtext",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "skills": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::skill.skill",
      "mappedBy": "jobs"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "internship",
        "full-time",
        "part-time"
      ]
    }
  }
}
