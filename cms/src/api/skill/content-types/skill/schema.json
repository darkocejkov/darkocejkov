{
  "kind": "collectionType",
  "collectionName": "skills",
  "info": {
    "singularName": "skill",
    "pluralName": "skills",
    "displayName": "Skill",
    "description": "A skill or technology that can be referenced across jobs, projects, and more"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "required": true,
      "default": "other",
      "enum": [
        "frontend",
        "backend",
        "module",
        "cloud",
        "devops",
        "design",
        "data",
        "mobile",
        "testing",
        "other",
        "software"
      ]
    },
    "level": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "familiar",
        "beginner",
        "intermediate",
        "advanced",
        "expert"
      ]
    },
    "description": {
      "type": "text"
    },
    "icon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "lastUsed": {
      "type": "date"
    },
    "jobs": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::job.job",
      "inversedBy": "skills"
    }
  }
}
